# ClearDeed — Environment Variables
# Copy this file to .env.local and fill in your values
# Never commit .env.local to version control

# ── ClearDeed Core ───────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://cleardeed.in
CLEARDEED_BASE_URL=https://cleardeed.in

# ── Supabase ─────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── Razorpay (Test Mode) ─────────────────────────────────────────────────────
# Found in: Razorpay Dashboard → Settings → API Keys
# Test credentials work with test.razorpay.com
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_SpLuOfVZDAdnM4
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
# For webhook signature verification (optional but recommended):
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ── Resend (Email) ───────────────────────────────────────────────────────────
# Found in: resend.com → API Keys
# Free tier: 100 emails/day
RESEND_API_KEY=re_HiKaachK_CBK38uHAUK767Czw2wnwXtwJ

# ── Bhulekh Fetcher ─────────────────────────────────────────────────────────
# The fetcher uses Playwright. No credentials needed — bhulekh.ori.nic.in is public.
# Optional: proxy for rate limiting
# BHEULKH_PROXY_URL=

# ── Development overrides ────────────────────────────────────────────────────
# Set to "development" to enable verbose logging
NODE_ENV=development

# ── Admin ────────────────────────────────────────────────────────────────────
# Token for accessing /admin (deprecated — review queue removed)
# ADMIN_VIEW_TOKEN=your-admin-token