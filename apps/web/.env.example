# ClearDeed — Environment Variables
# Copy this to .env.local and fill in real values

# ── Supabase ────────────────────────────────────────────────────────────────────
# Get these from your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Server-side only (never expose to client)
# Get this from Supabase: Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Founder-only admin view.
# Set this in Vercel and open /admin?token=<value>. The route fails closed when unset.
ADMIN_VIEW_TOKEN=generate-a-long-random-token

# Optional separate token for POST /api/report/create.
# If omitted, ADMIN_VIEW_TOKEN is accepted for report creation.
REPORT_CREATE_TOKEN=generate-a-different-long-random-token

# ── ClearDeed API ───────────────────────────────────────────────────────────────
# Optional: set a secret for rate limiting or webhook verification
# API_SECRET=your-secret-here

# Optional for production smoke checks.
# Defaults to https://v0-cleardeed.vercel.app when omitted.
CLEARDEED_BASE_URL=https://v0-cleardeed.vercel.app

# ── Development ────────────────────────────────────────────────────────────────
# Set to "development" to enable verbose logging
NODE_ENV=development
