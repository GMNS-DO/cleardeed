{
  "name": "cleardeed",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @cleardeed/web dev",
    "build": "pnpm --filter @cleardeed/web build",
    "dev:all": "pnpm -r dev",
    "build:all": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r tsc --noEmit"
  },
  "devDependencies": {
    "playwright": "^1.59.1",
    "pnpm": "^10.33.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.4"
  }
}
