{
  "name": "cleardeed",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "pnpm --filter @cleardeed/web dev",
    "build": "pnpm --filter @cleardeed/web build",
    "dev:all": "pnpm -r dev",
    "build:all": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p apps/web/tsconfig.json",
    "verify:prod": "node scripts/verify-production-launch.mjs"
  },
  "devDependencies": {
    "next": "^15.0.0",
    "playwright": "^1.59.1",
    "pnpm": "^10.33.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.4",
    "zod": "^3.23.0"
  },
  "dependencies": {
    "playwright-core": "^1.59.1",
    "tesseract.js": "^7.0.0"
  }
}
